# Copy this file to .env and fill in your values

# Gemini AI (optional - for AI caption generation)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Slack webhook URL (optional - can also set in the app UI)
# Get from: Slack > App Directory > Incoming Webhooks > Add
SLACK_WEBHOOK_URL=

# Server port (default: 3000)
PORT=3000

# Custom path to write the SQLite database file (e.g. on Railway Volume: /data/pipeline.db)
DATABASE_PATH=
